# App Settings
APP_NAME=RAG-PDF-System
APP_ENV=development
DEBUG=True
API_PREFIX=/api/v1

# Security
SECRET_KEY=your-super-secret-key-change-it
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM & Embedding (DashScope / Qwen)
DASHSCOPE_API_KEY=your-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v1
EMBEDDING_BATCH_SIZE=20
EMBEDDING_MAX_BATCH_SIZE=25
LLM_MODEL=qwen-max

# Milvus (Vector DB)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=rag_documents
MILVUS_DIMENSION=1536

# Redis (Celery Broker & Cache)
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=rag-documents
MINIO_SECURE=false

# SQL Database
DATABASE_URL=sqlite:///./rag_system.db

# RAG Config
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=20

# Rerank Config
ENABLE_RERANK=True
RERANK_MODEL=gte-rerank
RERANK_TOP_N=5

# Multi-hop Config
ENABLE_MULTI_HOP=True
MAX_HOP=3

# Memory Config
SHORT_TERM_MEMORY_TTL=3600
LONG_TERM_MEMORY_COLLECTION=user_memory
MEMORY_HISTORY_LIMIT=10

# Paths
UPLOAD_DIR=./data/raw
PROCESSED_DIR=./data/processed
VECTOR_DIR=./data/vectors
